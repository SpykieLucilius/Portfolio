<div class="navbar-container">
    <nav class="navbar">
        <ul class="navbar-list">
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/projects">Projects</a>
                <ul class="dropdown">
                    <li><a href="/projects/games">Games</a></li>
                    <li><a href="/projects/art">Art</a></li>
                    <li><a href="/projects/models">3D Models</a></li>
                    <li><a href="/projects/security">Cyber Security</a></li>
                    <li><a href="/projects/programming">Programming</a></li>
                    <li><a href="/projects/other">Other</a></li>
                </ul>
            </li>
            <li><a href="/contact">Contact</a></li>
        </ul>
    </nav>
</div>

<style>
    @reference "../../styles/global.css";

    .navbar-container {
        @apply 
        w-11/12
        max-w-4xl
        mx-auto 
        flex 
        justify-center
        mt-4;
    }

    .navbar {
        @apply 
        bg-gray-900 
        rounded-2xl
        text-white 
        p-2
        w-full;
    }

    .navbar-list {
        @apply 
        bg-gray-900 
        text-white 
        p-4 
        flex 
        space-x-6;
        justify-content: center;
    }

    .navbar-list li {
        @apply 
        relative;
        list-style-type: none;
    }

    .navbar-list li a {
        @apply 
        text-white 
        hover:text-gray-400;
        font-family: 'Roboto Mono', monospace;
        text-decoration: none;
    }

    .dropdown {
        @apply 
        rounded-2xl
        absolute 
        left-0 
        bg-gray-900 
        text-white 
        p-4
        hidden;
    }

    .dropdown li {
        @apply 
        mb-2;
    }

    .navbar-list li:hover .dropdown {
        @apply 
        block;
    }
</style>
