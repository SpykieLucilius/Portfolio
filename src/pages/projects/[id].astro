---
import Layout from "../../layouts/Layout.astro";
import Navbar from '../../components/navbar/Navbar.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const { data: project } = await supabase
    .from('projects')
    .select('*')
    .eq('id', id)
    .single();

if (!project) return Astro.redirect('/');

const displayDescription = project.detail_description || project.description || null;
---

<Layout>
    <Navbar />
    <section class="detail-section">

        <div class="detail-hero" style={project.image ? `background-image: url('${project.image}')` : ''}>
            <div class="detail-hero-overlay">
                <span class="detail-category">{project.category}</span>
                <h1 class="detail-title">{project.title}</h1>
            </div>
        </div>

        <div class="detail-body">

            {project.link && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-visit">
                    Visit Project →
                </a>
            )}

            {displayDescription ? (
                <p class="detail-description">{displayDescription}</p>
            ) : (
                <p class="detail-empty">No description available.</p>
            )}

            {project.detail_images && project.detail_images.length > 0 && (
                <div class="detail-gallery">
                    {project.detail_images.map((url: string) => (
                        <div class="gallery-frame" data-lightbox={url}>
                            <img src={url} alt={project.title} class="gallery-image" />
                        </div>
                    ))}
                </div>
            )}

        </div>

        <a href={`/projects/${project.category}`} class="btn-back">← Back to {project.category}</a>

    </section>

    <div id="lightbox" class="lightbox">
        <button id="lightbox-close" class="lightbox-close">✕</button>
        <img id="lightbox-img" src="" alt="" class="lightbox-img" />
    </div>
</Layout>

<style>
    @reference "../../styles/global.css";

    .detail-section {
        @apply flex flex-col flex-1 pb-10 w-11/12 mx-auto overflow-y-auto;
    }

    .detail-hero {
        @apply relative w-full rounded-2xl overflow-hidden bg-gray-900 mt-4 shrink-0;
        height: 340px;
        background-size: cover;
        background-position: center;
    }

    .detail-hero-overlay {
        @apply absolute bottom-0 left-0 w-full px-6 pt-16 pb-6;
        background-image: linear-gradient(to top, #111827 15%, rgba(0,0,0,0) 100%);
    }

    .detail-category {
        @apply text-xs text-gray-400 uppercase tracking-widest;
        font-family: 'Roboto Mono', monospace;
    }

    .detail-title {
        @apply text-3xl font-bold uppercase text-white mt-1;
        font-family: 'Roboto Mono', monospace;
        letter-spacing: 0.08em;
        text-shadow: 0 1px 6px rgba(0,0,0,0.8);
    }

    .detail-body {
        @apply flex flex-col gap-6 mt-8;
    }

    .btn-visit {
        @apply self-start bg-white text-gray-900 font-bold rounded-xl px-6 py-3 hover:bg-gray-200 transition-colors;
        font-family: 'Roboto Mono', monospace;
        text-decoration: none;
    }

    .detail-description {
        @apply text-gray-700 text-base leading-relaxed whitespace-pre-line;
        font-family: 'Roboto Mono', monospace;
        max-width: 72ch;
    }

    .detail-empty {
        @apply text-gray-400 text-sm italic;
        font-family: 'Roboto Mono', monospace;
    }

    .detail-gallery {
        @apply grid grid-cols-2 md:grid-cols-3 gap-4;
    }

    .gallery-frame {
        @apply bg-gray-900 rounded-2xl p-2 cursor-pointer transition-all duration-200;
        border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .gallery-frame:hover {
        @apply shadow-xl;
        border-color: rgba(255, 255, 255, 0.18);
        transform: scale(1.02);
    }

    .gallery-image {
        @apply rounded-xl object-cover w-full aspect-square;
    }

    .lightbox {
        @apply fixed inset-0 z-50 items-center justify-center;
        background: rgba(0, 0, 0, 0.92);
        display: none;
    }

    .lightbox.active {
        display: flex;
    }

    .lightbox-img {
        @apply rounded-2xl;
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
    }

    .lightbox-close {
        @apply absolute text-white text-xl font-bold cursor-pointer bg-gray-800 rounded-full border-0 hover:bg-gray-700 transition-colors;
        top: 1.5rem;
        right: 1.5rem;
        width: 2.5rem;
        height: 2.5rem;
        font-family: 'Roboto Mono', monospace;
    }

    .btn-back {
        @apply self-start text-gray-500 hover:text-gray-900 transition-colors mt-4 text-sm;
        font-family: 'Roboto Mono', monospace;
        text-decoration: none;
    }
</style>

<script>
    const lightbox = document.getElementById('lightbox')!;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close')!;

    function open(url: string) {
        lightboxImg.src = url;
        lightbox.classList.add('active');
    }

    function close() {
        lightbox.classList.remove('active');
        lightboxImg.src = '';
    }

    document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach(frame => {
        frame.addEventListener('click', () => open(frame.dataset.lightbox!));
    });

    closeBtn.addEventListener('click', close);
    lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
