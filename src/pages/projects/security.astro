---
import Layout from "../../layouts/Layout.astro";
import Navbar from '../../components/navbar/Navbar.astro';
import ProjectCard from '../../components/project/ProjectCard.astro';
import { supabase } from '../../lib/supabase';

const { data } = await supabase
    .from('projects')
    .select('*')
    .eq('category', 'security')
    .order('display_order');
const securityProjects = data ?? [];
---

<Layout>
    <Navbar />
    <section class ="securityprojects">
        
        <h1 class="Title">
            Security
        </h1>

        <div class="projects-grid">
            {securityProjects.map(project => (
                <ProjectCard 
                    id={project.id}
                    title={project.title} 
                    description={project.description} 
                    image={project.image} 
                    project_date={project.project_date}
                />
            ))}
        </div>

    </section>
</Layout>

<style>
    @reference "../../styles/global.css";

    .securityprojects {
        @apply flex flex-col flex-1 mt-4 pb-6 w-11/12 mx-auto overflow-y-auto px-4;
    }

    .Title {
        @apply text-black text-2xl font-bold mb-4;
        font-size: 200%;
        font-family: "Roboto Mono", monospace;
    }

    .projects-grid {
        @apply grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 w-full;
    }

</style>