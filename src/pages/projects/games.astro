---
import Layout from "../../layouts/Layout.astro";
import Navbar from '../../components/navbar/Navbar.astro';
import ProjectCard from "../../components/project/ProjectCard.astro";
import { supabase } from '../../lib/supabase';

const { data } = await supabase
    .from('projects')
    .select('*')
    .eq('category', 'games')
    .order('display_order');
const games = data ?? [];
---

<Layout>
    <Navbar />
    <section class ="gameprojects">

        <h1 class="Title">
            Games
        </h1>

        <div class="projects-grid">
            {games.map(game => (
                <ProjectCard 
                    id={game.id}
                    title={game.title} 
                    description={game.description} 
                    image={game.image} 
                />
            ))}
        </div>
    </section>
</Layout>

<style>
    @reference "../../styles/global.css";

    .gameprojects {
        @apply flex flex-col flex-1 mt-4 pb-6 w-11/12 mx-auto overflow-y-auto px-4;
    }

    .Title {
        @apply text-black text-2xl font-bold mb-4;
        font-size: 200%;
        font-family: "Roboto Mono", monospace;
    }

    .projects-grid {
        @apply grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 w-full;
    }

</style>