---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/navbar/Navbar.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/projects');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'delete') {
    await supabaseAdmin.from('projects').delete().eq('id', id);
    return Astro.redirect('/admin/projects');
  }

  if (action === 'remove_detail_image') {
    const urlToRemove = form.get('image_url') as string;
    const { data: current } = await supabaseAdmin
      .from('projects')
      .select('detail_images')
      .eq('id', id)
      .single();
    const updated = (current?.detail_images ?? []).filter((u: string) => u !== urlToRemove);
    await supabaseAdmin.from('projects').update({ detail_images: updated }).eq('id', id);
    return Astro.redirect(`/admin/projects/${id}`);
  }


  let imageUrl = form.get('current_image') as string | null;
  const imageFile = form.get('image_file') as File;

  if (imageFile && imageFile.size > 0) {
    const filename = `${Date.now()}-${imageFile.name}`;
    const buffer = await imageFile.arrayBuffer();
    const { error: uploadError } = await supabaseAdmin.storage
      .from('project-images')
      .upload(filename, buffer, { contentType: imageFile.type });

    if (!uploadError) {
      const { data: { publicUrl } } = supabaseAdmin.storage
        .from('project-images')
        .getPublicUrl(filename);
      imageUrl = publicUrl;
    }
  }

  const detailImageFiles = form.getAll('detail_image_files') as File[];
  const newDetailUrls: string[] = [];

  for (const file of detailImageFiles) {
    if (file.size === 0) continue;
    const filename = `${Date.now()}-${Math.random().toString(36).slice(2)}-${file.name}`;
    const buffer = await file.arrayBuffer();
    const { error } = await supabaseAdmin.storage
      .from('project-images')
      .upload(filename, buffer, { contentType: file.type });
    if (!error) {
      const { data: { publicUrl } } = supabaseAdmin.storage
        .from('project-images')
        .getPublicUrl(filename);
      newDetailUrls.push(publicUrl);
    }
  }

  const { data: currentProject } = await supabaseAdmin
    .from('projects')
    .select('detail_images')
    .eq('id', id)
    .single();
  const existingImages = currentProject?.detail_images ?? [];
  const finalDetailImages = [...existingImages, ...newDetailUrls];


  await supabaseAdmin.from('projects').update({
    title: form.get('title'),
    description: form.get('description'),
    image: imageUrl,
    link: form.get('link'),
    category: form.get('category'),
    display_order: Number(form.get('display_order')) || 0,
    detail_description: form.get('detail_description') || null,
    detail_images: finalDetailImages,
  }).eq('id', id);

  return Astro.redirect('/admin/projects');
}

const { data: project } = await supabaseAdmin
  .from('projects')
  .select('*')
  .eq('id', id)
  .single();

if (!project) return Astro.redirect('/admin/projects');
---

<Layout title="Edit Project">
  <Navbar />
  <section class="admin-section">
    <div class="admin-header">
      <h1 class="admin-title">Edit — {project.title}</h1>
      <a href="/admin/projects" class="btn-cancel">← Back</a>
    </div>

    {project.detail_images && project.detail_images.length > 0 && (
      <div class="gallery-section">
        <p class="gallery-section-label">Current Gallery</p>
        <div class="gallery-admin-grid">
          {project.detail_images.map((url: string) => (
            <div class="gallery-admin-item">
              <img src={url} alt="Gallery image" class="gallery-admin-thumb" />
              <form method="POST" class="remove-img-form" onsubmit="return confirm('Remove this image?')">
                <input type="hidden" name="_action" value="remove_detail_image" />
                <input type="hidden" name="image_url" value={url} />
                <button type="submit" class="btn-remove-img">✕</button>
              </form>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="form-card">
      <form method="POST" enctype="multipart/form-data" class="form">
        <input type="hidden" name="current_image" value={project.image ?? ''} />

        <div class="field">
          <label class="field-label">Title</label>
          <input class="field-input" type="text" name="title" value={project.title} required />
        </div>

        <div class="field">
          <label class="field-label">Description</label>
          <textarea class="field-input field-textarea" name="description">{project.description}</textarea>
        </div>

        <div class="field">
          <label class="field-label">Image</label>
          {project.image && (
            <img src={project.image} alt="Current image" class="image-preview" />
          )}
          <input class="field-file" type="file" name="image_file" accept="image/*" />
          <span class="field-hint">Leave empty to keep the current image.</span>
        </div>

        <div class="field">
          <label class="field-label">Link</label>
          <input class="field-input" type="text" name="link" value={project.link ?? ''} placeholder="https://" />
        </div>

        <div class="field">
          <label class="field-label">Category</label>
          <select class="field-input" name="category" required>
            {['games','art','models','security','programming','other'].map(c => (
              <option value={c} selected={project.category === c}>{c}</option>
            ))}
          </select>
        </div>

        <div class="field">
          <label class="field-label">Display order</label>
          <input class="field-input field-short" type="number" name="display_order" value={project.display_order} min="0" />
        </div>

        <div class="field">
          <label class="field-label">Detail Description</label>
          <textarea class="field-input field-textarea field-textarea-tall" name="detail_description">{project.detail_description}</textarea>
        </div>

        <div class="field">
          <label class="field-label">Add Gallery Images</label>
          <input class="field-file" type="file" name="detail_image_files" accept="image/*" multiple />
          <span class="field-hint">New uploads are appended to the gallery above.</span>
        </div>

        <div class="form-actions">
          <button class="btn-primary" type="submit">Save changes</button>
          <a href="/admin/projects" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </div>

    <form method="POST" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this project?')">
      <input type="hidden" name="_action" value="delete" />
      <button class="btn-danger" type="submit">Delete project</button>
    </form>
  </section>
</Layout>

<style>
  @reference "../../../styles/global.css";

  .admin-section {
    @apply flex flex-col flex-1 mt-4 pb-6 w-11/12 mx-auto overflow-y-auto;
  }

  .admin-header {
    @apply flex items-center justify-between mb-6;
  }

  .admin-title {
    @apply text-black font-bold;
    font-size: 200%;
    font-family: 'Roboto Mono', monospace;
  }

  .form-card {
    @apply bg-gray-900 rounded-2xl p-8;
  }

  .form {
    @apply flex flex-col gap-6;
  }

  .field {
    @apply flex flex-col gap-2;
  }

  .field-label {
    @apply text-gray-400 text-xs uppercase tracking-widest;
    font-family: 'Roboto Mono', monospace;
  }

  .field-input {
    @apply bg-gray-800 text-white rounded-xl px-4 py-3 outline-none border border-gray-700 focus:border-gray-400 transition-colors;
    font-family: 'Roboto Mono', monospace;
    font-size: 95%;
  }

  .field-textarea {
    @apply resize-none;
    min-height: 100px;
  }

  .field-file {
    @apply text-gray-300 text-sm;
    font-family: 'Roboto Mono', monospace;
  }

  .field-hint {
    @apply text-gray-500 text-xs;
    font-family: 'Roboto Mono', monospace;
  }

  .field-short {
    max-width: 120px;
  }

  .image-preview {
    @apply rounded-xl object-cover;
    max-height: 140px;
    width: auto;
  }

  .form-actions {
    @apply flex items-center gap-4 mt-2;
  }

  .btn-primary {
    @apply bg-white text-gray-900 font-bold rounded-xl px-6 py-3 hover:bg-gray-200 transition-colors cursor-pointer;
    font-family: 'Roboto Mono', monospace;
  }

  .btn-cancel {
    @apply text-gray-400 hover:text-white transition-colors;
    font-family: 'Roboto Mono', monospace;
    font-size: 90%;
    text-decoration: none;
  }

  .delete-form {
    @apply mt-4;
  }

  .btn-danger {
    @apply bg-transparent text-red-500 border border-red-500 rounded-xl px-6 py-3 hover:bg-red-500 hover:text-white transition-colors cursor-pointer;
    font-family: 'Roboto Mono', monospace;
    font-size: 90%;
  }

  .field-textarea-tall {
  min-height: 200px;
  }

  .gallery-section {
    @apply mb-4;
  }

  .gallery-section-label {
    @apply text-gray-400 text-xs uppercase tracking-widest mb-2;
    font-family: 'Roboto Mono', monospace;
  }

  .gallery-admin-grid {
    @apply grid grid-cols-3 gap-3 mb-3;
  }

  .gallery-admin-item {
    @apply relative;
  }

  .gallery-admin-thumb {
    @apply rounded-xl object-cover w-full;
    aspect-ratio: 1;
  }

  .remove-img-form {
    @apply absolute top-1 right-1;
  }

  .btn-remove-img {
    @apply bg-red-600 text-white rounded-full w-6 h-6 text-xs flex items-center justify-center cursor-pointer border-0 hover:bg-red-500 transition-colors;
  }

</style>
