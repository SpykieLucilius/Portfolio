---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/navbar/Navbar.astro';
import { supabaseAdmin } from '../../../lib/supabase';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  let imageUrl: string | null = null;
  const imageFile = form.get('image_file') as File;

  if (imageFile && imageFile.size > 0) {
    const filename = `${Date.now()}-${imageFile.name}`;
    const buffer = await imageFile.arrayBuffer();
    const { error: uploadError } = await supabaseAdmin.storage
      .from('project-images')
      .upload(filename, buffer, { contentType: imageFile.type });

    if (!uploadError) {
      const { data: { publicUrl } } = supabaseAdmin.storage
        .from('project-images')
        .getPublicUrl(filename);
      imageUrl = publicUrl;
    }
  }

const detailImageFiles = form.getAll('detail_image_files') as File[];
const detailImageUrls: string[] = [];

for (const file of detailImageFiles) {
  if (file.size === 0) continue;
  const filename = `${Date.now()}-${Math.random().toString(36).slice(2)}-${file.name}`;
  const buffer = await file.arrayBuffer();
  const { error: uploadError } = await supabaseAdmin.storage
    .from('project-images')
    .upload(filename, buffer, { contentType: file.type });
  if (!uploadError) {
    const { data: { publicUrl } } = supabaseAdmin.storage
      .from('project-images')
      .getPublicUrl(filename);
    detailImageUrls.push(publicUrl);
  }
}

  const { data: newProject } = await supabaseAdmin.from('projects').insert({
    title: form.get('title'),
    description: form.get('description'),
    image: imageUrl,
    link: form.get('link'),
    category: form.get('category'),
    display_order: Number(form.get('display_order')) || 0,
    detail_description: form.get('detail_description') || null,
    detail_images: detailImageUrls,
    project_date: Number(form.get('project_date')) || null
  }).select('id').single();

  const selectedTagIds = form.getAll('tags') as string[];
  if (newProject && selectedTagIds.length > 0) {
    await supabaseAdmin.from('project_tags').insert(
      selectedTagIds.map(tagId => ({ project_id: newProject.id, tag_id: tagId }))
    );
  }

  return Astro.redirect('/admin/projects');
}

const { data: tags } = await supabaseAdmin.from('tags').select('*').order('name');
---

<Layout title="New Project">
  <Navbar />
  <section class="admin-section">
    <div class="admin-header">
      <h1 class="admin-title">New Project</h1>
      <a href="/admin/projects" class="btn-cancel">← Back</a>
    </div>

    <div class="form-card">
      <form method="POST" enctype="multipart/form-data" class="form">
        <div class="field">
          <label class="field-label">Title</label>
          <input class="field-input" type="text" name="title" required />
        </div>

        <div class="field">
          <label class="field-label">Description</label>
          <textarea class="field-input field-textarea" name="description"></textarea>
        </div>

        <div class="field">
          <label class="field-label">Image</label>
          <input class="field-file" type="file" name="image_file" accept="image/*" />
        </div>

        <div class="field">
          <label class="field-label">Link</label>
          <input class="field-input" type="text" name="link" placeholder="https://" />
        </div>

        <div class="field">
          <label class="field-label">Category</label>
          <select class="field-input" name="category" required>
            <option value="games">Games</option>
            <option value="art">Art</option>
            <option value="models">3D Models</option>
            <option value="security">Cyber Security</option>
            <option value="programming">Programming</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="field">
          <label class="field-label">Display order</label>
          <input class="field-input field-short" type="number" name="display_order" value="0" min="0" />
        </div>
        
        <div class="field">
          <label class="field-label">Project Date</label>
          <input class="field-input" type="number" name="project_date" placeholder="YYYYMMDD" />
        </div>

        <div class="field">
          <label class="field-label">Detail Description</label>
          <textarea class="field-input field-textarea field-textarea-tall" name="detail_description"></textarea>
          <span class="field-hint">Full description shown on the project detail page.</span>
        </div>

        <div class="field">
          <label class="field-label">Gallery Images</label>
          <input class="field-file" type="file" name="detail_image_files" accept="image/*" multiple />
          <span class="field-hint">Select multiple files to create a gallery.</span>
        </div>

        <div class="field">
          <label class="field-label">Tags</label>
          <div class="tags-list" id="tags-list">
            {(tags ?? []).map(tag => (
              <label class="tag-option">
                <input type="checkbox" name="tags" value={tag.id} />
                {tag.name}
              </label>
            ))}
          </div>
          <input class="field-input new-tag-input" type="text" id="new-tag-input" placeholder="New tag... (press Enter to create)" autocomplete="off" />
        </div>

        <div class="form-actions">
          <button class="btn-primary" type="submit">Create project</button>
          <a href="/admin/projects" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</Layout>

<style>
  @reference "../../../styles/global.css";

  .admin-section {
    @apply flex flex-col flex-1 mt-4 pb-6 w-11/12 mx-auto overflow-y-auto;
  }

  .admin-header {
    @apply flex items-center justify-between mb-6;
  }

  .admin-title {
    @apply text-black font-bold;
    font-size: 200%;
    font-family: 'Roboto Mono', monospace;
  }

  .form-card {
    @apply bg-gray-900 rounded-2xl p-8;
  }

  .form {
    @apply flex flex-col gap-6;
  }

  .field {
    @apply flex flex-col gap-2;
  }

  .field-label {
    @apply text-gray-400 text-xs uppercase tracking-widest;
    font-family: 'Roboto Mono', monospace;
  }

  .field-input {
    @apply bg-gray-800 text-white rounded-xl px-4 py-3 outline-none border border-gray-700 focus:border-gray-400 transition-colors;
    font-family: 'Roboto Mono', monospace;
    font-size: 95%;
  }

  .field-textarea {
    @apply resize-none;
    min-height: 100px;
  }

  .field-file {
    @apply text-gray-300 text-sm;
    font-family: 'Roboto Mono', monospace;
  }

  .field-short {
    max-width: 120px;
  }

  .field-textarea-tall {
  min-height: 200px;
  }

  .tags-list {
    @apply flex flex-wrap gap-3;
  }

  .tag-option {
    @apply flex items-center gap-2 text-white text-sm cursor-pointer;
    font-family: 'Roboto Mono', monospace;
  }

  .tag-option input[type="checkbox"] {
    @apply accent-white w-4 h-4 cursor-pointer;
  }

  .new-tag-input {
    @apply mt-2;
    max-width: 320px;
  }

  .form-actions {
    @apply flex items-center gap-4 mt-2;
  }

  .btn-primary {
    @apply bg-white text-gray-900 font-bold rounded-xl px-6 py-3 hover:bg-gray-200 transition-colors cursor-pointer;
    font-family: 'Roboto Mono', monospace;
  }

  .btn-cancel {
    @apply text-gray-400 hover:text-white transition-colors;
    font-family: 'Roboto Mono', monospace;
    font-size: 90%;
    text-decoration: none;
  }
</style>

<script>
  const newTagInput = document.getElementById('new-tag-input') as HTMLInputElement | null;
  const tagsList = document.getElementById('tags-list');

  newTagInput?.addEventListener('keydown', async (e) => {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    const name = newTagInput.value.trim();
    if (!name) return;

    const res = await fetch('/api/tags/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name }),
    });

    if (res.ok) {
      const tag = await res.json();
      const label = document.createElement('label');
      label.className = 'tag-option';
      label.innerHTML = `<input type="checkbox" name="tags" value="${tag.id}" checked /> ${tag.name}`;
      tagsList?.appendChild(label);
      newTagInput.value = '';
    } else {
      const { error } = await res.json();
      alert(error ?? 'Failed to create tag');
    }
  });
</script>
