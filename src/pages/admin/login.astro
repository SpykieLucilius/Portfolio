---
import Layout from '../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email') as string;
  const password = form.get('password') as string;

  const supabase = createClient(
    import.meta.env.SUPABASE_URL,
    import.meta.env.SUPABASE_KEY
  );

  const { data, error } = await supabase.auth.signInWithPassword({ email, password });

  if (error || !data.session) {
    return Astro.redirect('/admin/login?error=1');
  }

  Astro.cookies.set('sb-access-token', data.session.access_token, {
    path: '/',
    httpOnly: true,
    secure: true,
    maxAge: 60 * 60 * 24,
  });

  return Astro.redirect('/admin/projects');
}

const hasError = Astro.url.searchParams.get('error');
---

<Layout title="Admin Login">
  <div class="login-page">
    <div class="login-card">
      <h1 class="login-title">Admin Panel</h1>
      {hasError && <p class="login-error">Invalid email or password.</p>}
      <form method="POST" class="login-form">
        <div class="field">
          <label class="field-label">Email</label>
          <input class="field-input" type="email" name="email" required />
        </div>
        <div class="field">
          <label class="field-label">Password</label>
          <input class="field-input" type="password" name="password" required />
        </div>
        <button class="btn-primary" type="submit">Login</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  @reference "../../styles/global.css";

  .login-page {
    @apply flex flex-1 items-center justify-center;
  }

  .login-card {
    @apply bg-gray-900 rounded-2xl p-10 w-full shadow-2xl;
    max-width: 420px;
  }

  .login-title {
    @apply text-white font-bold mb-8 text-center;
    font-family: 'Roboto Mono', monospace;
    font-size: 180%;
  }

  .login-error {
    @apply text-red-400 text-sm mb-4 text-center;
    font-family: 'Roboto Mono', monospace;
  }

  .login-form {
    @apply flex flex-col gap-5;
  }

  .field {
    @apply flex flex-col gap-2;
  }

  .field-label {
    @apply text-gray-400 text-xs uppercase tracking-widest;
    font-family: 'Roboto Mono', monospace;
  }

  .field-input {
    @apply bg-gray-800 text-white rounded-xl px-4 py-3 outline-none border border-gray-700 focus:border-gray-400 transition-colors;
    font-family: 'Roboto Mono', monospace;
    font-size: 95%;
  }

  .btn-primary {
    @apply bg-white text-gray-900 font-bold rounded-xl py-3 mt-2 hover:bg-gray-200 transition-colors cursor-pointer;
    font-family: 'Roboto Mono', monospace;
  }
</style>
